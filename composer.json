{
    "name": "meraki/schema-html",
    "description": "Render a meraki/schema as an HTML form.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nathan Bishop",
            "email": "nbish11@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "meraki/schema": "dev-main",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Meraki\\Schema\\Html\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Meraki\\Schema\\Html\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
